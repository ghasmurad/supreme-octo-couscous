{
  "rules": {
    "events": {
      "happy-hour-main": {
        ".read": true,
        ".write": true,
        "state": {
          ".validate": "newData.hasChildren(['teams','current','updatedAt']) || newData.hasChildren(['teams','current','initializedAt'])"
        },
        "players": {
          "$playerId": {
            ".validate": "newData.hasChildren(['name','joinedAt']) || !newData.exists()"
          }
        },
        "answers": {
          "$roundId": {
            "$playerId": {
              ".validate": "newData.hasChildren(['updatedAt']) || !newData.exists()"
            }
          }
        },
        "teamAnswers": {
          "$roundId": {
            "$teamId": {
              ".validate": "newData.hasChildren(['answer','submittedBy','updatedAt']) || !newData.exists()"
            }
          }
        }
      }
    }
  }
}
